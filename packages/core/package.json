{
  "name": "@dynauth/core",
  "version": "0.0.1",
  "private": false,
  "description": "All-in-one dynauth package",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@dynauth/ui": "workspace:*",
    "@dynauth/ui-mui": "workspace:*",
    "@dynauth/server": "workspace:*"
  },
  "peerDependencies": {
    "@mui/material": ">=5.0.0",
    "@emotion/react": ">=11.0.0",
    "@emotion/styled": ">=11.0.0",
    "express": ">=4.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
